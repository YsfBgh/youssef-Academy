VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-or-publishable-key

# Optional browser defaults for local Ollama.
VITE_AI_COACH_PROVIDER=ollama
VITE_AI_COACH_ENDPOINT=/ollama/api/chat
VITE_AI_COACH_MODEL=qwen3:latest

# Optional Netlify proxy variables.
# For local development, direct Ollama above is simpler.
# For a hosted provider, keep secrets server-side and do not use a VITE_ prefix.
AI_COACH_PROVIDER=ollama
AI_COACH_ENDPOINT=http://localhost:11434/api/chat
AI_COACH_MODEL=qwen3:latest
AI_COACH_API_KEY=
